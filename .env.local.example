# Twinx AI Portal — környezeti változók sablon
# Másold .env.local néven és töltsd ki. NE kerüljön verziókezelésbe.

# --- Supabase (1-2. fázis) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Csak szerveroldalon (API route-ok), SOHA ne kliensen:
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (3. fázis) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- AI API-k (4-5. fázis) ---
PERPLEXITY_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=

# --- E-mail (6. fázis, Resend) ---
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=
# Opcionális feladó (domain hitelesítés után a sajátodra cseréld):
RESEND_FROM=Twinx <onboarding@resend.dev>

# --- Videó pipeline (6.6. fázis) ---
LUMA_API_KEY=
SHOTSTACK_API_KEY=
# Publikus alap-URL a webhookokhoz (lokál: ngrok tunnel URL; éles: a domain):
APP_URL=http://localhost:3000
# Saját titok a videó-webhookok ellenőrzéséhez (bármilyen random string):
VIDEO_WEBHOOK_SECRET=
# Opcionális felülírás:
# LUMA_MODEL=ray-2
# LUMA_DURATION=5s
# SHOTSTACK_ENV=stage   (teszthez 'stage', élesben 'v1')
